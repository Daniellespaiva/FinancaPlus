<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinancaPlus.Views.LoginPage"
             Title="LoginPage">
    
    <VerticalStackLayout
         VerticalOptions="Center"
        Spacing="10"
        Padding="5">

        <Label 
            Text="Sistema de Login"
        HorizontalOptions="Center" />

        <Label Text="E-mail" />
            <Entry x:Name="txt_email" 
            Placeholder="Digite seu e-mail"/>

        <Label Text="Senha" />
        <Entry x:Name="txt_senha" 
               Placeholder="Digite sua senha"/>

        <Button Text="Entrar" x:Name="btn_entar" 
                Clicked="btn_entar_Clicked" />


        <Button Text="Registrar" x:Name="btn_registrar"
                Clicked="btn_registrar_Clicked" />

    </VerticalStackLayout>
</ContentPage>