<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinancaPlus.Views.TelaPrincipal"
             NavigationPage.HasNavigationBar="False"
             Title="TelaPrincipal">

   
    <VerticalStackLayout>

        <HorizontalStackLayout VerticalOptions="Start" Margin="10" Padding="10" Spacing="40">
            <Label>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Olá, " />
                        <Span Text="{Binding UsuarioLogado.Nome}" />
                    </FormattedString>
                </Label.FormattedText>
                <Label.FontSize>24</Label.FontSize>
                <Label.HorizontalOptions>Start</Label.HorizontalOptions>
            </Label>

            <Image Source="images_2.jpeg" 
           HeightRequest="50" 
           WidthRequest="50" 
           Margin="10,0,0,0"/>

            <!-- Botão de Configurações ao lado da saudação -->
            <Button Text="⚙" 
            FontSize="20"
            BackgroundColor="Transparent"
             x:Name="BTN_configuracoes"
                 
             Clicked="BTN_configuracoes_Clicked"/>


        </HorizontalStackLayout>

        <HorizontalStackLayout Padding="10" Spacing="50" Margin="1" HorizontalOptions="FillAndExpand">
            <!-- Saldo inicial -->
            <StackLayout HorizontalOptions="FillAndExpand">
                <Label Text="Saldo inicial:" FontSize="20" HorizontalOptions="StartAndExpand"/>
                <Frame BorderColor="Black" CornerRadius="10" Padding="10"  BackgroundColor="LightGray" HorizontalOptions="FillAndExpand">
                         <!-- Label do saldo inicial -->
                        <Label x:Name="LBL_saldoInicial" Text="R$ 0,00" FontAttributes="Bold" HorizontalOptions="FillAndExpand"/>
                 </Frame>
            </StackLayout>

            <!-- Saldo disponível -->
            <StackLayout HorizontalOptions="FillAndExpand">
                <Label Text="Saldo disponível:" FontSize="20" HorizontalOptions="StartAndExpand"/>
                <Frame BorderColor="Black" CornerRadius="10" Padding="10" BackgroundColor="LightGray" HorizontalOptions="FillAndExpand">
                    <Label x:Name="LBL_saldo" Text="R$ 0,00" FontAttributes="Bold" HorizontalOptions="FillAndExpand"/>
                </Frame>
            </StackLayout>
        </HorizontalStackLayout>




        <HorizontalStackLayout HorizontalOptions="FillAndExpand"  Margin="1" Padding="10" Spacing="5">

                    <Button Text="Adiciona Receitas" FontSize="12"
                     BackgroundColor="Green"
                x:Name="BTN_receitas"
                Clicked="BTN_receitas_Clicked" />

                    <Button Text="Adicionar Despesas" FontSize="12"
                    BackgroundColor="Red"
                x:Name="BTN_despesas"
                Clicked ="BTN_despesas_Clicked" />

                    <Button Text="Adicionar Metas" FontSize="12"
                    BackgroundColor="Blue"
                x:Name="BTN_definirMetas"
                Clicked="BTN_definirMetas_Clicked" />
        </HorizontalStackLayout>

                <Label Text="Gasto por categoria" Padding="10" Margin="5"
               FontSize="20"
               HorizontalOptions="FillAndExpand" />

                <HorizontalStackLayout HorizontalOptions="Start" Spacing="20" Padding="10">
                    <!-- Lista de categorias à esquerda -->
                    <StackLayout VerticalOptions="Center" Spacing="5" HorizontalOptions="End">
                        <Label Text="Moradia - 30%" FontSize="16" TextColor="#FF5733"/>
                        <Label Text="Alimento - 25%" FontSize="16" TextColor="#33FF57"/>
                        <Label Text="Transporte - 20%" FontSize="16" TextColor="#3357FF" />
                        <Label Text="Outros - 25%" FontSize="16" TextColor="#FF33A5"/>
                    </StackLayout>
                    
                    

                </HorizontalStackLayout>

        

                <Button Text="Gerar relatório" BackgroundColor="RoyalBlue" Margin="40"  Padding="10"
                x:Name="BTN_relatorios"
                        HorizontalOptions="CenterAndExpand"
                Clicked="BTN_relatorios_Clicked" />
          
        
    </VerticalStackLayout>
</ContentPage>
    
    